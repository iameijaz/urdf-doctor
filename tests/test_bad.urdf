<?xml version="1.0"?>
<!-- test_bad.urdf — intentionally broken URDF for urdf-doctor testing -->
<robot name="test_robot">

  <!-- GOOD: proper root link -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.5 0.3 0.1"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><box size="0.5 0.3 0.1"/></geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0"
               iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>

  <!-- ERROR: zero mass -->
  <link name="wheel_left">
    <visual>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </visual>
    <collision>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- ERROR: negative ixx -->
  <link name="wheel_right">
    <visual>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </visual>
    <collision>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="-0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- WARN: missing inertial -->
  <link name="camera_mount">
    <visual>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
      <material name="undefined_material"/>
    </visual>
    <collision>
      <geometry><box size="0.05 0.05 0.05"/></geometry>
    </collision>
  </link>

  <!-- WARN: visual only, no collision -->
  <link name="decorative_panel">
    <visual>
      <geometry><box size="0.1 0.1 0.01"/></geometry>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
               iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <!-- ERROR: file:// URI -->
  <link name="sensor_link">
    <visual>
      <geometry>
        <mesh filename="file:///home/user/robot_ws/meshes/sensor.stl"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0"
               iyy="0.0005" iyz="0.0" izz="0.0005"/>
    </inertial>
  </link>

  <!-- WARN: duplicate link name -->
  <link name="wheel_left">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- orphan link — not connected to any joint -->
  <link name="orphan_link">
    <visual>
      <geometry><box size="0.1 0.1 0.1"/></geometry>
    </visual>
  </link>

  <!-- GOOD joint -->
  <joint name="base_to_wheel_left" type="revolute">
    <parent link="base_link"/>
    <child link="wheel_left"/>
    <origin xyz="-0.2 0.15 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="5"/>
  </joint>

  <!-- ERROR: zero axis vector -->
  <joint name="base_to_wheel_right" type="revolute">
    <parent link="base_link"/>
    <child link="wheel_right"/>
    <origin xyz="-0.2 -0.15 0" rpy="0 0 0"/>
    <axis xyz="0 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="5"/>
  </joint>

  <!-- ERROR: limits inverted -->
  <joint name="base_to_camera" type="revolute">
    <parent link="base_link"/>
    <child link="camera_mount"/>
    <axis xyz="0 0 1"/>
    <limit lower="1.5" upper="-1.5" effort="5" velocity="2"/>
  </joint>

  <!-- WARN: missing origin, zero effort -->
  <joint name="base_to_panel" type="prismatic">
    <parent link="base_link"/>
    <child link="decorative_panel"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="0.1" effort="0" velocity="0"/>
  </joint>

  <!-- WARN: floating joint -->
  <joint name="base_to_sensor" type="floating">
    <parent link="base_link"/>
    <child link="sensor_link"/>
  </joint>

  <!-- ERROR: non-existent parent link -->
  <joint name="bad_joint" type="fixed">
    <parent link="nonexistent_link"/>
    <child link="camera_mount"/>
  </joint>

</robot>
